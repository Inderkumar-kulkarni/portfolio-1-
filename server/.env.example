# Server
PORT=5000

# Local MongoDB connection string
# Default for a local MongoDB instance with no auth, database name "portfolio"
MONGODB_URI=mongodb://localhost:27017/portfolio

# Gmail account used to SEND the notification email
# Use a Gmail App Password here, NOT your normal Gmail password.
# Generate one at: Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_USER=youraddress@gmail.com
EMAIL_APP_PASSWORD=your16characterapppassword

# Where the contact form notifications should be delivered
RECEIVER_EMAIL=inderkumarkulkarni@gmail.com

# Frontend origin allowed to call this API (Vite dev server default)
CLIENT_ORIGIN=http://localhost:5173
